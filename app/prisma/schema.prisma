generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BUYER
  ORGANIZER
  ADMIN
  STAFF
}

enum OrganizerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ON_SALE
  PAUSED
  ENDED
  FROZEN
  REJECTED
}

enum TicketStatus {
  VALID
  LISTED
  CHECKED_IN
  FROZEN
}

enum ListingStatus {
  ACTIVE
  LOCKED       // reserved: a buyer checkout is in progress (mirrors on-chain lock)
  CANCELLING   // calldata returned to seller; waiting for on-chain ListingCancelled event
  SOLD
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  PIX
  CARD
  USDC
}

enum PurchaseStatus {
  PENDING
  PAID
  MINTING
  COMPLETED
  REFUNDING
  REFUNDED
  FAILED
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  PAID
  FAILED
}

model User {
  id             String     @id @default(cuid())
  privyId        String     @unique @map("privy_id")
  email          String?    @unique
  walletAddress  String?    @unique @map("wallet_address")
  role           UserRole   @default(BUYER)
  createdAt      DateTime   @default(now()) @map("created_at")

  organizer   Organizer?
  purchases   Purchase[]
  withdrawals Withdrawal[]
  checkins    Checkin[]

  @@map("users")
}

model Organizer {
  id            String          @id @default(cuid())
  userId        String          @unique @map("user_id")
  companyName   String          @map("company_name")
  document      String          // CNPJ
  payoutWallet  String          @map("payout_wallet")
  status        OrganizerStatus @default(PENDING)
  createdAt     DateTime        @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id])
  events Event[]

  @@map("organizers")
}

model Event {
  id                   String      @id @default(cuid())
  organizerId          String      @map("organizer_id")
  title                String
  description          String?
  venue                String
  city                 String
  coverImageUrl        String?     @map("cover_image_url")
  eventDate            DateTime    @map("event_date")
  ticketPriceUsdc      Decimal     @map("ticket_price_usdc") @db.Decimal(18, 6)
  maxTickets           Int?        @map("max_tickets")
  platformFeeBps       Int         @default(800) @map("platform_fee_bps")
  royaltyBps           Int         @default(1000) @map("royalty_bps")
  royaltyOrgShareBps   Int         @default(8000) @map("royalty_org_share_bps")
  status               EventStatus @default(DRAFT)
  onchainEventId       Int?        @map("onchain_event_id")
  royaltySplitterAddr  String?     @map("royalty_splitter_address")
  createTxHash         String?     @map("create_tx_hash")
  createdAt            DateTime    @default(now()) @map("created_at")

  organizer Organizer  @relation(fields: [organizerId], references: [id])
  tickets   Ticket[]
  purchases Purchase[]

  @@map("events")
}

model Ticket {
  tokenId      Int          @id @map("token_id")
  eventId      String       @map("event_id")
  ownerAddress String       @map("owner_address")
  ticketNumber Int          @map("ticket_number")
  seat         String?
  facePrice    Decimal      @map("face_price") @db.Decimal(18, 6)
  status       TicketStatus @default(VALID)
  mintTxHash   String?      @map("mint_tx_hash")
  mintedAt     DateTime?    @map("minted_at")

  event    Event     @relation(fields: [eventId], references: [id])
  listing  Listing?
  purchase Purchase?
  checkin  Checkin?

  @@unique([eventId, ticketNumber])
  @@map("tickets")
}

model Listing {
  id               String        @id @default(cuid())
  onchainListingId Int?          @unique @map("onchain_listing_id")
  tokenId          Int           @unique @map("token_id")
  sellerAddress    String        @map("seller_address")
  price            Decimal       @db.Decimal(18, 6)
  paymentToken     String        @map("payment_token")
  expiresAt        DateTime?     @map("expires_at")
  status           ListingStatus @default(ACTIVE)
  txHash           String?       @map("tx_hash")
  createdAt        DateTime      @default(now()) @map("created_at")

  ticket    Ticket     @relation(fields: [tokenId], references: [tokenId])
  purchases Purchase[]

  @@map("listings")
}

model Purchase {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  eventId       String         @map("event_id")
  listingId     String?        @map("listing_id")
  tokenId       Int?           @unique @map("token_id")
  amountBrl     Decimal        @map("amount_brl") @db.Decimal(10, 2)
  amountUsdc    Decimal        @map("amount_usdc") @db.Decimal(18, 6)
  fxRate        Decimal        @map("fx_rate") @db.Decimal(10, 6)
  pspProvider   String?        @map("psp_provider")
  pspChargeId   String         @unique @map("psp_charge_id")
  paymentMethod PaymentMethod  @map("payment_method")
  status        PurchaseStatus @default(PENDING)
  mintTxHash    String?        @map("mint_tx_hash")
  createdAt     DateTime       @default(now()) @map("created_at")
  paidAt        DateTime?      @map("paid_at")
  completedAt   DateTime?      @map("completed_at")

  user    User     @relation(fields: [userId], references: [id])
  event   Event    @relation(fields: [eventId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])
  ticket  Ticket?  @relation(fields: [tokenId], references: [tokenId])

  @@map("purchases")
}

model Withdrawal {
  id                 String           @id @default(cuid())
  userId             String           @map("user_id")
  amount             Decimal          @map("amount") @db.Decimal(18, 6) // off-ramped asset amount (USDC today, not necessarily forever)
  amountBrl          Decimal          @map("amount_brl") @db.Decimal(10, 2)
  fxRate             Decimal          @map("fx_rate") @db.Decimal(10, 6)
  pixKey             String           @map("pix_key")
  status             WithdrawalStatus @default(REQUESTED)
  usdcTransferTxHash String?          @map("usdc_transfer_tx_hash")
  createdAt          DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("withdrawals")
}

model Checkin {
  id          String   @id @default(cuid())
  tokenId     Int      @unique @map("token_id")
  eventId     String   @map("event_id")
  staffUserId String   @map("staff_user_id")
  scannedAt   DateTime @default(now()) @map("scanned_at")

  ticket Ticket @relation(fields: [tokenId], references: [tokenId])
  staff  User   @relation(fields: [staffUserId], references: [id])

  @@map("checkins")
}

model SyncState {
  contractAddress    String @id @map("contract_address")
  lastProcessedBlock BigInt @map("last_processed_block")

  @@map("sync_state")
}
